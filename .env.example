# ─── Database (Neon) ──────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# ─── Auth0 ────────────────────────────────────────────────────────────────
# Tenant domain (no protocol, no trailing slash). Auth0 dashboard: "Domain".
AUTH0_DOMAIN=dev-2x1dti3irhuz62jc.us.auth0.com
# API "Identifier" registered under Auth0 → APIs. The SPA requests tokens for
# this audience; the server validates incoming JWTs against it.
AUTH0_AUDIENCE=https://api.soulseerpsychics.vercel.app
# Machine-to-Machine application authorized for the Auth0 Management API.
# Required scopes: create:users, read:users, update:users, delete:users.
AUTH0_MGMT_CLIENT_ID=your_auth0_mgmt_client_id_here
AUTH0_MGMT_CLIENT_SECRET=your_auth0_mgmt_client_secret_here
# Auth0 database connection name for creating reader accounts via Management API
AUTH0_DB_CONNECTION=Username-Password-Authentication

# ─── Agora (real-time voice/video/chat) ───────────────────────────────────
AGORA_APP_ID=your_agora_app_id_here
AGORA_APP_CERTIFICATE=your_agora_app_certificate_here
# Agora REST API credentials (Console → Project → Customer ID/Secret)
# Required for RTMP push/recording features
AGORA_CUSTOMER_ID=your_agora_customer_id_here
AGORA_CUSTOMER_SECRET=your_agora_customer_secret_here
# Agora Chat (RTM) credentials
AGORA_CHAT_APP_ID=your_agora_chat_app_id_here
AGORA_ORG_ID=your_agora_org_id_here

# ─── Stripe ──────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# ─── Cloudinary (profile image uploads) ──────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name_here
CLOUDINARY_API_KEY=your_cloudinary_api_key_here
CLOUDINARY_API_SECRET=your_cloudinary_api_secret_here

# ─── Brevo (transactional email) ─────────────────────────────────────────
BREVO_API_KEY=your_brevo_api_key_here

# ─── Cron Security ────────────────────────────────────────────────────────
# Secret used to authenticate Vercel Cron job requests to /api/cron/billing-tick
CRON_SECRET=your_cron_secret_here

# ─── Server ──────────────────────────────────────────────────────────────
PORT=5000
CORS_ORIGIN=http://localhost:5173
NODE_ENV=development
