# ─── Database (Neon) ──────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# ─── Auth0 ────────────────────────────────────────────────────────────────
# Tenant domain (no protocol, no trailing slash). Auth0 dashboard: "Domain".
# Alias accepted: AUTH0_DOMAIN_URL
AUTH0_DOMAIN=dev-2x1dti3irhuz62jc.us.auth0.com
# API "Identifier" registered under Auth0 → APIs. The SPA requests tokens for
# this audience; the server validates incoming JWTs against it.
# Alias accepted: AUTH0_IDENTIFIER
AUTH0_AUDIENCE=https://api.soulseerpsychics.vercel.app
# Machine-to-Machine application authorized for the Auth0 Management API.
# Required scopes: create:users, read:users, update:users, delete:users.
# Aliases accepted: AUTH0_APP_ID (client id), AUTH0_CLIENT_SECRET (secret)
AUTH0_MGMT_CLIENT_ID=693253d01a25578349323a8d
AUTH0_MGMT_CLIENT_SECRET=your_auth0_mgmt_client_secret_here
# Production frontend URL. If CORS_ORIGIN is unset/localhost, this is used.
# AUTH0_ALLOWED_URL=https://soulseerpsychics.vercel.app

# ─── Agora (real-time voice/video) ───────────────────────────────────────
AGORA_APP_ID=
AGORA_APP_CERTIFICATE=

# ─── Stripe ──────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# ─── Cloudinary (profile image uploads) ──────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Brevo (transactional email) ─────────────────────────────────────────
BREVO_API_KEY=

# ─── Server ──────────────────────────────────────────────────────────────
PORT=5000
CORS_ORIGIN=http://localhost:5173
NODE_ENV=development
