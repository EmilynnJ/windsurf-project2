{
  "name": "@soulseer/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "security:check": "npm audit"
  },
  "dependencies": {
    "@soulseer/shared": "file:../shared",
    "agora-access-token": "^2.0.4",
    "agora-token": "^2.0.5",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.45.1",
    "express": "^4.21.2",
    "express-jwt": "^8.4.1",
    "helmet": "^8.1.0",
    "jwks-rsa": "^3.1.0",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.13.1",
    "pino": "^9.9.0",
    "pino-http": "^10.0.0",
    "stripe": "^17.2.0",
    "uuid": "^11.0.3",
    "vite": "8.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.18",
    "@types/express": "^4.17.25",
    "@types/express-jwt": "^7.4.1",
    "@types/multer": "^1.4.12",
    "@types/pg": "^8.11.10",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/ui": "^4.1.0",
    "drizzle-kit": "^0.31.9",
    "eslint": "^8.50.0",
    "eslint-plugin-security": "^1.7.1",
    "tsx": "^4.20.5",
    "typescript": "^5.7.3",
    "vitest": "^4.1.0"
  }
}
