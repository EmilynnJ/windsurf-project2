# ─── API ─────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:5000
# WebSocket URL — must point at a long-running server (e.g. Fly.io). Vercel
# serverless functions cannot hold persistent WS connections, so the WS
# server lives on Fly via server/src/production.ts. In local dev this is
# the same host as VITE_API_URL. In production, set this to your Fly app
# URL with the wss:// scheme, e.g. wss://windsurf-project2.fly.dev
VITE_WS_URL=ws://localhost:5000

# ─── Agora (client-side App ID only) ────────────────────────────────────
VITE_AGORA_APP_ID=your-agora-app-id

# ─── Stripe (publishable key only) ──────────────────────────────────────
VITE_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here
